# Example environment configuration - copy to .env and fill in your values

# Environment
ENV=development
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# OpenAI API
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Database
DATABASE_URL=postgresql://voice_user:voice_password@localhost:5432/voice_agent_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=voice_agent_db
DB_USER=voice_user
DB_PASSWORD=voice_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Session Configuration
SESSION_TTL=3600
MAX_SESSION_DURATION=1800

# Feature Flags
ENABLE_LATENCY_TRACKING=True
ENABLE_CAMPAIGN_SCHEDULER=True

# Language Support
SUPPORTED_LANGUAGES=en,hi,ta

# Campaign Settings
CAMPAIGN_CHECK_INTERVAL=300
MAX_CONCURRENT_CAMPAIGNS=5

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Audio Processing
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=4096

# Webhooks (optional)
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=30

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
